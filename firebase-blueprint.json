{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a registered user",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User access level" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "PlaylistItem": {
      "title": "Playlist Item",
      "description": "A video saved to a user's playlist",
      "type": "object",
      "properties": {
        "videoId": { "type": "string" },
        "title": { "type": "string" },
        "thumbnail": { "type": "string" },
        "channelName": { "type": "string" },
        "channelAvatar": { "type": "string" },
        "duration": { "type": "string" },
        "views": { "type": "string" },
        "postedAt": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["videoId", "title", "addedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/playlist/{videoId}": {
      "schema": "PlaylistItem",
      "description": "User's saved videos"
    }
  }
}
