rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - photoURL: string
    //   - role: string (required, 'user' or 'admin')
    //   - createdAt: timestamp
    //   - lastLogin: timestamp
    //
    // Collection: users/{userId}/playlist
    // Document ID: {videoId}
    // Fields:
    //   - videoId: string (required)
    //   - title: string (required)
    //   - thumbnail: string
    //   - channelName: string
    //   - channelAvatar: string
    //   - duration: string
    //   - views: string
    //   - postedAt: string
    //   - addedAt: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         (request.auth.token.email == "altamapes@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['user', 'admin'];
    }

    function isValidPlaylistItem(data) {
      return data.keys().hasAll(['videoId', 'title', 'addedAt']) &&
             data.videoId is string &&
             data.title is string &&
             data.title.size() < 500;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
      
      match /playlist/{videoId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) && isValidPlaylistItem(request.resource.data);
      }
    }
  }
}
